	local AllItems = {}
	local AllSections = {}
	local AllCleanups = {}

	local isSearching = false

	local function registerItem(frame, name, sectionRef)
		table.insert(AllItems, {
			frame = frame,
			name = string.lower(name),
			section = sectionRef
		})
	end

	local function registerSection(sectionF, secBtt, arrowIcon, isOpenRef, uiListLayout3, line1)
		table.insert(AllSections, {
			sectionF = sectionF,
			secBtt = secBtt,
			arrowIcon = arrowIcon,
			isOpenRef = isOpenRef,
			uiListLayout3 = uiListLayout3,
			line1 = line1
		})
	end

	local function openSectionRaw(sec)
		local contentHeight = sec.uiListLayout3.AbsoluteContentSize.Y
		sec.sectionF.Size = UDim2.new(0, 494, 0, 33 + contentHeight)
		sec.arrowIcon.Rotation = 0
		sec.line1.Visible = true
	end

	local function closeSectionRaw(sec)
		sec.sectionF.Size = UDim2.new(0, 494, 0, 33)
		sec.arrowIcon.Rotation = 180
	end

	SearchTextBox:GetPropertyChangedSignal("Text"):Connect(function()
		local query = string.lower(SearchTextBox.Text)

		if query == "" then
			isSearching = false

			for _, item in pairs(AllItems) do
				item.frame.Visible = true
			end

			task.defer(function()
				for _, sec in pairs(AllSections) do
					sec.secBtt.Active = true
					sec.arrowIcon.Visible = true

					if sec.isOpenRef.value then
						openSectionRaw(sec)
					else
						closeSectionRaw(sec)
					end
				end
			end)

			return
		end

		isSearching = true

		for _, sec in pairs(AllSections) do
			sec.secBtt.Active = false
			sec.arrowIcon.Visible = false
			openSectionRaw(sec)
		end

		for _, item in pairs(AllItems) do
			item.frame.Visible = string.find(item.name, query, 1, true) ~= nil
		end

		task.defer(function()
			for _, sec in pairs(AllSections) do
				local contentHeight = sec.uiListLayout3.AbsoluteContentSize.Y
				sec.sectionF.Size = UDim2.new(0, 494, 0, 33 + contentHeight)
			end
		end)
	end)
	
	--// UI Drag system	
	local dragging
	local dragInput
	local dragStart
	local startPos
	
	UI.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = UI.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging and UI.Size then			
			local delta = input.Position - dragStart
			local dragTime = .04
			local SmoothDrag = {}

			SmoothDrag.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)

			local TweenUI = TS:Create(UI, TweenInfo.new(dragTime), SmoothDrag)
			TweenUI:Play()

			local TweenShadow = TS:Create(Shadow, TweenInfo.new(dragTime), SmoothDrag)
			TweenShadow:Play()			
		end
	end)
	
